;; lai configuration file
;; Place this as lai.alisp in your project root or ~/.lai/config.alisp

;; Backend
(def backend-type "openai")

;; API base URL (appends /chat/completions automatically)
;; OpenAI:    https://api.openai.com/v1
;; OpenRouter: https://openrouter.ai/api/v1
;; llama.cpp: http://localhost:8080/v1
(def backend-url "https://openrouter.ai/api/v1")

;; Model name (provider-specific)
;; OpenRouter examples: anthropic/claude-3.5-sonnet, openai/gpt-4o, meta-llama/llama-3.1-70b-instruct
;; Free models: google/gemma-4-31b-it:free, nvidia/nemotron-3-super-120b-a12b:free
;; OpenAI examples: gpt-4o, gpt-4o-mini, o1
(def backend-model "google/gemma-4-26b-a4b-it:free")

(def backend-temperature 0.7)    ;; 0.0 = deterministic, 1.0 = creative
(def backend-max-tokens 4096)    ;; max response length

;; Agent
(def agent-max-turns 20)              ;; max code-execute loops per query
(def agent-max-context-tokens 8192)   ;; truncate history when exceeded

;; Security
;; "off" = no checks
;; "confirm" = prompt before dangerous ops
;; "strict" = block dangerous ops
(def security-mode "Confirm")

;; Network
(def security-allow-network true)
(def security-blocked-domains (quote ()))     ;; block these domains
(def security-allowed-domains (quote ()))     ;; empty = allow all (if allow-network=true)

;; Dangerous operations
(def security-require-confirm-rm true)
(def security-require-confirm-sudo true)
(def security-require-confirm-write-system true)
(def security-require-confirm-eval true)

;; Blocked commands (always blocked in strict mode)
(def security-blocked-commands (quote ("rm -rf /" "mkfs" ":(){ :|:& };:")))

;; Blocked alisp functions (always blocked in strict mode)
(def security-blocked-functions (quote ("exit" "setenv")))

;; System paths (blocked from writes)
(def security-blocked-paths (quote ("/etc" "/boot" "/sys" "/proc")))

;; Sandbox: restrict file writes to these paths (empty = disabled)
(def security-sandbox-paths (quote ()))

;; Rate limiting
(def security-max-ops-per-turn 50)       ;; max alisp operations per turn

;; Output size limit (bytes)
(def security-max-output-bytes 1048576)  ;; 1MB

;; Audit log (empty = disabled)
(def security-audit-log "")
