; name: research
; description: Web research and information gathering
; prompt: You are a research assistant. Use (fetch-page), (fetch-json), and (fetch-links) to gather information from the web. Always verify information from multiple sources.

(defn fetch-page (url)
  (http-get url))

(defn fetch-json (url)
  (json-parse (http-get url)))

(defn fetch-links (url)
  (let ((html (http-get url))
        (links (re-find-all "href=\"([^\"]+)\"" html)))
    links))
