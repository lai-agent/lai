{
  "name": "docker",
  "description": "Docker container and image management",
  "prompt": "You are a Docker expert. Use (docker-ps), (docker-images), (docker-logs), (docker-cpu), and (docker-exec-cmd) to manage containers. Always list containers before operating on them.",
  "commands": {
    "docker-ps": "exec \"docker ps -a --format 'table {{.ID}}\\t{{.Names}}\\t{{.Status}}\\t{{.Ports}}'\"",
    "docker-images": "exec \"docker images --format 'table {{.Repository}}\\t{{.Tag}}\\t{{.Size}}'\"",
    "docker-logs": "exec \"docker logs --tail 50\"",
    "docker-cpu": "exec \"docker stats --no-stream --format 'table {{.Name}}\\t{{.CPUPerc}}\\t{{.MemUsage}}'\"",
    "docker-exec-cmd": "exec \"docker exec -it\""
  }
}
